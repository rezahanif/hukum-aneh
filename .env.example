# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CREDENTIALS_PATH=backend/configs/firebase-service-account.json

# 9Router (LLM + Embeddings proxy)
ROUTER9_BASE_URL=http://localhost:4000/v1
ROUTER9_API_KEY=your-router-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Instagram (Meta Graph API)
IG_ACCESS_TOKEN=your-ig-access-token
IG_ACCOUNT_ID=your-ig-account-id

# Image Generation
IMAGE_GEN_PROVIDER=openai
IMAGE_GEN_API_KEY=your-key
IMAGE_GEN_BASE_URL=https://api.openai.com/v1

# Scheduler
DISCOVERY_INTERVAL=1h
STUCK_JOB_THRESHOLD=6h

# Python Scraper
PYTHON_PATH=python3
SCRAPER_SCRIPT_PATH=backend/python/scraper/scrape.py

# Sources
SOURCES_PATH=backend/configs/sources.json
